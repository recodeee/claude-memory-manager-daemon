# Required
MEMORY_ROOT=/home/deadpool/.claude/projects/-home-deadpool/memory

# Loop cadence
TICK_INTERVAL_SEC=900          # 15 min between full audits
MIN_IDLE_SEC=300               # require this many seconds since last memory mtime before mutating

# Behavior
DRY_RUN=true                   # set to false to allow actual writes
MODEL=claude-haiku-4-5-20251001
MAX_TURNS=12                   # per-tick agent turn budget

# Auth — leave blank to use the local Claude Code subscription session
ANTHROPIC_API_KEY=

# Logging
LOG_FILE=/tmp/claude-memory-manager.log
PID_FILE=/tmp/claude-memory-manager.pid
LOCK_FILE=/tmp/claude-memory-manager.lock
