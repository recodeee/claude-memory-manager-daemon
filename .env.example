# --- daemon ---
MEMORY_ROOT=/home/deadpool/.claude/projects/-home-deadpool/memory
TICK_INTERVAL_SEC=900          # 15 min between full audits
MIN_IDLE_SEC=300               # require this idle time on MEMORY_ROOT before mutating
DRY_RUN=true                   # set to false to allow Write/Edit
MODEL=claude-haiku-4-5-20251001
MAX_TURNS=12

# --- binaries the daemon shells out to ---
CLAUDE_BIN=claude              # absolute path also accepted
AUTHMUX_BIN=authmux

# --- claude account selection (optional) ---
# CLAUDE_CONFIG_DIR=/home/deadpool/.claude-accounts/account2
CLAUDE_ACCOUNTS_DIR=/home/deadpool/.claude-accounts

# --- runtime files ---
LOG_FILE=/tmp/claude-memory-manager.log
PID_FILE=/tmp/claude-memory-manager.pid
LOCK_FILE=/tmp/claude-memory-manager.lock
STATUS_SOCK=/tmp/claude-memory-manager.sock

# --- logging filter (tracing-subscriber EnvFilter syntax) ---
# CMMD_LOG=info,claude_memory_manager_daemon=debug
