[Unit]
Description=Claude Memory Manager Daemon (Rust)
Documentation=https://github.com/recodeee/claude-memory-manager-daemon
After=default.target

[Service]
Type=simple
WorkingDirectory=%h/Documents/claude-memory-manager-daemon
ExecStart=%h/Documents/claude-memory-manager-daemon/target/release/cmmd run
Restart=on-failure
RestartSec=30
Environment=DRY_RUN=true
StandardOutput=append:%t/claude-memory-manager.log
StandardError=append:%t/claude-memory-manager.log
# Hardening — daemon needs read on $HOME, write on memory dir + /tmp.
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.claude/projects/-home-deadpool/memory /tmp
PrivateTmp=false
NoNewPrivileges=true

[Install]
WantedBy=default.target

# Install:
#   cargo build --release
#   mkdir -p ~/.config/systemd/user
#   cp systemd/claude-memory-manager.service ~/.config/systemd/user/
#   systemctl --user daemon-reload
#   systemctl --user enable --now claude-memory-manager
#   journalctl --user -u claude-memory-manager -f
